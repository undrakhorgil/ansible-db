<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Oracle Grid Environment Summary</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 24px; color: #222; }
    h1, h2 { margin-bottom: 8px; }
    table { border-collapse: collapse; width: 100%; margin-bottom: 18px; }
    th, td { border: 1px solid #ddd; padding: 8px; text-align: left; vertical-align: top; }
    th { background: #f5f5f5; width: 28%; }
    .muted { color: #666; font-size: 0.92em; }
    code { background: #f7f7f7; padding: 1px 4px; border-radius: 4px; }
  </style>
</head>
<body>
  <h1>Oracle Grid Environment Summary</h1>
  <p class="muted">Generated by Ansible on {{ ansible_date_time.date }} {{ ansible_date_time.time }} (Ansible inventory: {{ oracle_managed_host_inventory }}) — <strong>Oracle Restart</strong> (single-node HAS)</p>

  <h2>Grid / host</h2>
  <table>
    <tr><th>Cluster name (installer)</th><td>{{ summary_rac_cluster_name | default('') }}</td></tr>
    <tr><th>Oracle node hostname</th><td>{{ summary_rac_primary_node | default('') }}</td></tr>
    <tr><th>DNS domain (/etc/hosts)</th><td>{{ oracle_hosts_domain }}</td></tr>
  </table>

  <h2>Networking</h2>
  <table>
    <tr><th>Public subnet</th><td>{{ oracle_public_subnet }}</td></tr>
    {% if oracle_use_private_network | default(false) | bool %}
    <tr><th>Private subnet</th><td>{{ oracle_private_subnet | default('') }}</td></tr>
    <tr><th>Grid NIC role (private)</th><td><code>{{ oracle_grid_iface_role_private }}</code></td></tr>
    {% else %}
    <tr><th>Private interconnect</th><td class="muted">disabled (public network only)</td></tr>
    {% endif %}
    <tr><th>Grid NIC role (public)</th><td><code>{{ oracle_grid_iface_role_public }}</code></td></tr>
    <tr><th>Grid interface list override</th><td><code>{{ oracle_grid_network_interface_list | default('') }}</code></td></tr>
  </table>

  <h2>Managed host</h2>
  <table>
    <tr><th>Name</th><th>Host IP (SSH)</th></tr>
    {% for n in oracle_hosts %}
    <tr>
      <td>{{ n.name }}</td>
      <td>{{ n.host_ip }}</td>
    </tr>
    {% endfor %}
  </table>

  <h2>Oracle paths</h2>
  <table>
    <tr><th>ORACLE_BASE</th><td><code>{{ oracle_base }}</code></td></tr>
    <tr><th>GRID_HOME</th><td><code>{{ grid_home }}</code></td></tr>
    <tr><th>ORACLE_HOME</th><td><code>{{ oracle_home }}</code></td></tr>
    <tr><th>Inventory</th><td><code>{{ oracle_inventory }}</code></td></tr>
  </table>

  <h2>Users &amp; groups</h2>
  <table>
    <tr><th>grid user</th><td><code>{{ grid_user }}</code></td></tr>
    <tr><th>oracle user</th><td><code>{{ oracle_user }}</code></td></tr>
    <tr><th>oinstall</th><td><code>{{ oinstall_group }}</code></td></tr>
    <tr><th>dba</th><td><code>{{ dba_group }}</code></td></tr>
    <tr><th>asmadmin</th><td><code>{{ asmadmin_group }}</code></td></tr>
    <tr><th>asmdba</th><td><code>{{ asmdba_group }}</code></td></tr>
    <tr><th>asmoper</th><td><code>{{ asmoper_group }}</code></td></tr>
  </table>

  <h2>Software inputs</h2>
  <table>
    <tr><th>Grid ZIP</th><td><code>{{ oracle_grid_software_zip }}</code></td></tr>
    <tr><th>DB ZIP</th><td><code>{{ oracle_db_software_zip }}</code></td></tr>
    <tr><th>Preinstall package</th><td><code>{{ oracle_preinstall_package }}</code></td></tr>
  </table>

  <h2>Grid setup</h2>
  <table>
    <tr><th>Install option</th><td><code>HA_CONFIG</code></td></tr>
    <tr><th>Use bundled response file</th><td><code>{{ oracle_grid_silent_use_bundled_response_file }}</code></td></tr>
    <tr><th>Execute root scripts in OUI</th><td><code>{{ oracle_grid_rootconfig_executeRootScript }}</code></td></tr>
    <tr><th>ASM disk discovery string</th><td><code>{{ grid_asm_disk_discovery_string }}</code></td></tr>
    <tr><th>ASM disk list override</th><td><code>{{ grid_asm_disk_list | default('') }}</code></td></tr>
    <tr><th>CRS DG redundancy</th><td><code>{{ grid_asm_diskgroup_redundancy }}</code></td></tr>
  </table>

  <h2>ASM devices (udev / stable naming)</h2>
  <table>
    <tr><th>asm_disks (partition targets)</th><td><code>{{ asm_disks | default([]) | join(', ') }}</code></td></tr>
    <tr><th>asm_symlinks</th><td>
      {% for s in asm_symlinks | default([]) %}
        <div><code>{{ s.name }}</code> ⇢ <code>{{ (s.id_path | default(s.device | default(''))) }}</code></div>
      {% endfor %}
    </td></tr>
    <tr><th>Wipe stale headers</th><td><code>{{ asm_wipe_stale_headers | default('') }}</code> ({{ asm_wipe_header_mb | default('') }} MiB)</td></tr>
  </table>

  <h2>ASM diskgroups</h2>
  <table>
    <tr>
      <th>Name</th>
      <th>Used for Grid CRS</th>
      <th>Redundancy</th>
      <th>Disks</th>
    </tr>
    {% for dg in asm_diskgroups %}
    <tr>
      <td>{{ dg.name }}</td>
      <td>{{ dg.used_for_grid_crs }}</td>
      <td>{{ dg.redundancy }}</td>
      <td>{{ (dg.disks | default([])) | join(', ') }}</td>
    </tr>
    {% endfor %}
  </table>

  <h2>DBCA</h2>
  <table>
    <tr><th>GDB name</th><td>{{ dbca_gdbname }}</td></tr>
    <tr><th>SID</th><td>{{ dbca_sid }}</td></tr>
    <tr><th>PDB name</th><td>{{ dbca_pdb_name }}</td></tr>
    <tr><th>Character set</th><td>{{ dbca_character_set }}</td></tr>
    <tr><th>Data diskgroup</th><td>{{ dbca_data_diskgroup }}</td></tr>
    <tr><th>Recovery diskgroup</th><td>{{ dbca_recovery_diskgroup }}</td></tr>
    <tr><th>Recovery area size (MB)</th><td>{{ dbca_recovery_area_size_mb }}</td></tr>
    <tr><th>Ignore prereq checks</th><td><code>{{ dbca_ignore_prereq_checks | default('') }}</code></td></tr>
  </table>

  <p class="muted">Generated: {{ ansible_date_time.date }} {{ ansible_date_time.time }}</p>
</body>
</html>
