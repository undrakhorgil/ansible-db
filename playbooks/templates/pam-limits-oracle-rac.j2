# Oracle Grid Infrastructure + DB software (Ansible playbooks/templates)
# Aligns with oracle-database-preinstall style limits; satisfies CVU memlock (PRVE-0059).
{% for u in [grid_user, oracle_user] %}
{{ u }} soft    nofile    1024
{{ u }} hard    nofile    65536
{{ u }} soft    nproc     16384
{{ u }} hard    nproc     16384
{{ u }} soft    stack     10240
{{ u }} hard    stack     32768
{{ u }} soft    core      unlimited
{{ u }} hard    core      unlimited
{{ u }} soft    memlock   unlimited
{{ u }} hard    memlock   unlimited
{% endfor %}
